# ======================
# DADA Backend — Environment Variables
# ======================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---- Server ----
NODE_ENV=development          # development | staging | production
PORT=3000

# ---- Database ----
DATABASE_URL=postgresql://dada:dada@localhost:5432/dada
DB_SSL=false                  # true in production (rejectUnauthorized: true)
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=                   # min 256-bit random string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=         # different from JWT_SECRET
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# ---- OTP Providers ----
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_WHATSAPP_FROM=
EASYSENDSMS_API_KEY=
OTP_SENDER=DadaDrive
OTP_EXPIRES_IN=5              # minutes
OTP_MAX_ATTEMPTS=3

# ---- Firebase (FCM) ----
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ---- Flouci Payment ----
FLOUCI_APP_TOKEN=
FLOUCI_APP_SECRET=

# ---- HERE Maps ----
HERE_API_KEY=

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated

# ---- Sentry ----
SENTRY_DSN=

# ---- Logging ----
LOG_LEVEL=debug               # error | warn | info | http | debug
